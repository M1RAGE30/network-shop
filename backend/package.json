{
  "name": "network-shop-v2-backend",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nodemon src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint .",
    "test": "tsx --test test/**/*.test.ts",
    "check": "npm run lint && npm run build && npm run test && npm audit"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.8.1"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
